# ==========================
# Public (exposed to client)
# ==========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==========================
# Server only
# ==========================
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# ==========================
# Feature flags
# ==========================
# Cuando MOCK_IMAGE_GEN=true, Replicate no se llama; se devuelven placeholders.
# Útil para desarrollo sin gastar créditos.
MOCK_IMAGE_GEN=false

# Cuando MOCK_STRATEGY=true, Strategy Agent devuelve un output canned (de seed).
MOCK_STRATEGY=false

# Cuando MOCK_INFLUENCER=true, Influencer Matching devuelve los primeros 5 del seed.
MOCK_INFLUENCER=false
