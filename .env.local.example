# ==========================
# Public (exposed to client)
# ==========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ==========================
# Server only
# ==========================
DATABASE_URL=
DIRECT_URL=
SUPABASE_SECRET_KEY=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# REPLICATE_API_TOKEN — MOCKEADO por ahora. La idea es migrar a un modelo NVIDIA
# gratis después; mientras MOCK_IMAGE_GEN=true no se usa esta key.
REPLICATE_API_TOKEN=

# ==========================
# Feature flags
# ==========================
# Image generation está MOCKEADA por defecto: Creative Engine devuelve placeholders
# Unsplash y NO llama a Replicate. Cambiar a false solo cuando esté listo el
# modelo NVIDIA gratis (ver design D3 / spec creative-engine).
MOCK_IMAGE_GEN=true

# Cuando MOCK_STRATEGY=true, Strategy Agent devuelve un output canned (de seed).
MOCK_STRATEGY=false

# Cuando MOCK_INFLUENCER=true, Influencer Matching devuelve los primeros 5 del seed.
MOCK_INFLUENCER=false
